# ============================================================
# AI Call 外呼机器人 - 全局环境配置模板
#
# 复制为 .env 并填写真实值。未填写的项将使用 Mock 实现。
# 本文件由 NestJS API 和 Python Voice Agent 共同读取。
# Dashboard 前端变量见 apps/dashboard/.env.local（NEXT_PUBLIC_*）
# FunASR Server 专用变量见 services/funasr-server/.env
# ============================================================

# ===== 通用 =====
NODE_ENV=development

# ===== NestJS 后端 API (apps/api) =====
DATABASE_URL=postgresql://ai_call:ai_call_password@localhost:5432/ai_call
REDIS_URL=redis://localhost:6379
# 浏览器允许访问 API/FunASR 的来源，多个值用逗号分隔
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=3d
DEFAULT_ADMIN_EMAIL=admin@ai-call.local
DEFAULT_ADMIN_PASSWORD=admin123
# Cookie 安全配置：dev 默认 false（HTTP 可写入），prod 默认 true（HTTPS）
# 同源代理后 dev 用 SameSite=Lax，prod 用 SameSite=None（如需跨域）或 Lax
COOKIE_SECURE=
# 内部服务鉴权；生产环境必须设置为随机长字符串
SERVICE_API_TOKEN=

# ===== 外部知识库服务（I:\ai-knowledge）=====
# ai-call 会保留 /api/knowledge-base 契约，并将请求代理到该服务。
# 例：ai-knowledge 若暴露 http://localhost:3010/api/knowledge-base，则这里填 http://localhost:3010/api
# 未配置时使用 ai-call 内置 mock 知识库。
KNOWLEDGE_SERVICE_BASE_URL=
KNOWLEDGE_SERVICE_API_TOKEN=
KNOWLEDGE_SERVICE_TIMEOUT_MS=5000

# ===== FreeSWITCH =====
FREESWITCH_SIP_HOST=localhost
FREESWITCH_SIP_PORT=5060
FREESWITCH_ESL_HOST=localhost
# Windows 本机 FreeSWITCH 用 8021；Docker Desktop 推荐映射到宿主机 18021
FREESWITCH_ESL_PORT=18021
FREESWITCH_ESL_PASSWORD=ClueCon
# 本机联调：user/{to}；生产 SIP 中继：sofia/gateway/default/{to}
FREESWITCH_DIAL_STRING=user/{to}
# Windows 官方安装包通常不含 mod_audio_fork，先关闭以验证基础呼叫
FREESWITCH_AUDIO_FORK_ENABLED=false
FREESWITCH_AUDIO_FORK_URL=ws://127.0.0.1:8090/audio-stream
# audio_fork：服务端回裸 PCM；audio_stream：服务端回 base64 JSON
FREESWITCH_AUDIO_MODULE=audio_fork
FREESWITCH_SHARED_RECORDINGS_HOST=I:\ai-call\freeswitch\recordings
FREESWITCH_SHARED_RECORDINGS_CONTAINER=/var/lib/freeswitch/recordings
# 旧版 audio_fork 的 WAV 分片时长；越大越平滑，越小首音越快
FREESWITCH_PLAYBACK_CHUNK_MS=960
FROM_NUMBER=1000

# ===== 电话接入（Twilio，测试用）=====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Python Voice Agent (services/voice-agent) =====
# WebSocket 服务端（接收 FreeSWITCH mod_audio_fork 连接）
VOICE_AGENT_WS_HOST=0.0.0.0
VOICE_AGENT_WS_PORT=8090
VOICE_AGENT_WS_PATH=/audio-stream
# 配置后 /audio-stream metadata 及 demo WS query 必须携带 token
VOICE_AGENT_WS_TOKEN=
# 独立 API worker 进程：处理事务 outbox
OUTBOX_WORKER_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=1000

# 独立 API worker 进程：扫描 scheduledAt <= now 的 pending 任务并写入 outbox
TASK_SCHEDULER_ENABLED=true
TASK_SCHEDULER_INTERVAL_MS=5000
TASK_SCHEDULER_BATCH_SIZE=20
# GlobalConfig 中 nonHolidayOnly=true 时使用，多个日期用逗号分隔。
OUTBOUND_HOLIDAYS=

# NestJS API 地址（Voice Agent 调用业务接口）
API_BASE_URL=http://localhost:3001/api

# ===== AI Provider 选择 =====
# LLM_PROVIDER: deepseek | qwen | mock | legacy
LLM_PROVIDER=mock
# TTS_PROVIDER: qwen | cosyvoice | mock
TTS_PROVIDER=mock

# ===== FunASR STT（本地部署）=====
FUNASR_WS_URL=ws://localhost:10095
FUNASR_MODE=2pass
FUNASR_HOTWORDS=

# ===== LLM 配置（适配器模式 + LangChain）=====
# DeepSeek (LLM_PROVIDER=deepseek)
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen DashScope (LLM_PROVIDER=qwen)
LLM_QWEN_API_KEY=
LLM_QWEN_MODEL=qwen-plus
LLM_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Legacy httpx 直调 (LLM_PROVIDER=legacy)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ===== TTS 配置 =====
# CosyVoice 本地部署 (TTS_PROVIDER=cosyvoice，默认端口 50000)
COSYVOICE_BASE_URL=http://localhost:50000
COSYVOICE_SPEAKER=中文女
COSYVOICE_SAMPLE_RATE=22050

# Qwen-TTS Realtime 云端 (TTS_PROVIDER=qwen)
# DASHSCOPE_API_KEY 与 LLM_QWEN_API_KEY 是同一阿里云百炼密钥，填入即可启用
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TTS_MODEL=qwen3-tts-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# 音色克隆：Qwen 声音复刻先用参考音频创建 voice，再用该 voice 生成试听
QWEN_VOICE_CLONE_MODEL=qwen-voice-enrollment
QWEN_VOICE_CLONE_TARGET_MODEL=qwen3-tts-vc-2026-01-22
QWEN_VOICE_CLONE_LANGUAGE=zh
QWEN_TTS_LANGUAGE_TYPE=Chinese
DASHSCOPE_TTS_TIMEOUT_MS=60000
# 默认不使用原始参考音频伪装成生成结果；本地调试需要兜底时可显式设为 true
VOICE_CLONE_PREVIEW_FALLBACK=false

# ===== VAD（WebRTC VAD 前置粗筛）=====
VAD_AGGRESSIVENESS=3
VAD_FRAME_MS=20
VAD_PRE_BUFFER_MS=300
VAD_SILENCE_CONFIRM_FRAMES=10
VAD_SPEECH_CONFIRM_FRAMES=3

# ===== ASR 门控（避免 TTS/回声被识别成用户）=====
ASR_TTS_GATE_ENABLED=true
ASR_TTS_TAIL_GUARD_MS=500
BARGE_IN_DURING_TTS_ENABLED=false
BARGE_IN_MIN_MS=500
BARGE_IN_RMS_THRESHOLD=0.08

# ===== 对话循环 =====
MAX_TURNS=30
TURN_TIMEOUT_S=30

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== SMS 动作转发 =====
# 配置后，流程 Action 节点（sms 类型）将 POST {to,template,params,taskId,attemptId} 到短信网关。
SMS_GATEWAY_URL=
SMS_GATEWAY_TOKEN=

# ===== API/Webhook 动作转发 =====
# 流程 Action 节点（api 类型）只允许访问白名单主机，多个 hostname 用逗号分隔。
ACTION_WEBHOOK_ALLOWLIST=
