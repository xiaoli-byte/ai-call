generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TaskFlow {
  id          String            @id @default(uuid())
  name        String
  description String            @default("")
  status      String            @default("draft")
  nodes       Json              @default("[]")
  edges       Json              @default("[]")
  version     Int               @default(0)
  versions    TaskFlowVersion[]
  tasks       OutboundTask[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("task_flows")
}

model TaskFlowVersion {
  id          String         @id @default(uuid())
  flowId      String         @map("flow_id")
  flow        TaskFlow       @relation(fields: [flowId], references: [id], onDelete: Restrict)
  version     Int
  name        String
  description String         @default("")
  nodes       Json
  edges       Json
  tasks       OutboundTask[]
  createdAt   DateTime       @default(now()) @map("created_at")

  @@unique([flowId, version])
  @@index([flowId, createdAt])
  @@map("task_flow_versions")
}

model OutboundTask {
  id            String            @id @default(uuid())
  to            String
  from          String
  scenario      String
  variables     Json              @default("{}")
  status        String            @default("pending")
  scheduledAt   DateTime          @map("scheduled_at")
  calledAt      DateTime?         @map("called_at")
  endedAt       DateTime?         @map("ended_at")
  duration      Int?
  outcome       String?
  recordingUrl  String?           @map("recording_url")
  intentTags    String[]          @default([]) @map("intent_tags")
  attemptCount  Int               @default(0) @map("attempt_count")
  flowId        String?           @map("flow_id")
  flow           TaskFlow?        @relation(fields: [flowId], references: [id], onDelete: Restrict)
  flowVersionId String?           @map("flow_version_id")
  flowVersion   TaskFlowVersion?  @relation(fields: [flowVersionId], references: [id], onDelete: Restrict)
  transcripts   TranscriptTurn[]
  events        CallEvent[]
  attempts      CallAttempt[]
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status, scheduledAt])
  @@index([flowVersionId])
  @@map("outbound_tasks")
}

model CallAttempt {
  id             String            @id @default(uuid())
  taskId         String            @map("task_id")
  task           OutboundTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptNo      Int               @map("attempt_no")
  providerCallId String?           @unique @map("provider_call_id")
  status         String            @default("calling")
  startedAt      DateTime          @default(now()) @map("started_at")
  ringingAt      DateTime?         @map("ringing_at")
  answeredAt     DateTime?         @map("answered_at")
  endedAt        DateTime?         @map("ended_at")
  duration       Int?
  hangupCause    String?           @map("hangup_cause")
  recordingUrl   String?           @map("recording_url")
  transcripts    TranscriptTurn[]
  events         CallEvent[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([taskId, attemptNo])
  @@index([taskId, createdAt])
  @@index([status, startedAt])
  @@map("call_attempts")
}

model TranscriptTurn {
  id        String       @id @default(uuid())
  taskId    String       @map("task_id")
  task      OutboundTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptId String?      @map("attempt_id")
  attempt   CallAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  role      String
  content   String
  timestamp Float
  emotion   String?
  externalId String?      @map("external_id")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@index([attemptId, createdAt])
  @@unique([taskId, externalId])
  @@map("transcript_turns")
}

model CallEvent {
  id        String       @id @default(uuid())
  taskId    String       @map("task_id")
  task      OutboundTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptId String?      @map("attempt_id")
  attempt   CallAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  type      String
  payload   Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@index([attemptId, createdAt])
  @@map("call_events")
}

model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  type          String
  payload       Json      @default("{}")
  status        String    @default("pending")
  attempts      Int       @default(0)
  availableAt   DateTime  @default(now()) @map("available_at")
  processedAt   DateTime? @map("processed_at")
  lastError     String?   @map("last_error")
  lockedAt      DateTime? @map("locked_at")
  lockedBy      String?   @map("locked_by")
  deduplicationKey String? @unique @map("deduplication_key")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status, availableAt])
  @@index([lockedAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String        @map("password_hash")
  name          String
  status        String        @default("active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  roles         UserRole[]
  sessions      UserSession[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String           @default("")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String           @default("")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}
