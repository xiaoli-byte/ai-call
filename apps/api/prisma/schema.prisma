generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model OutboundScenario {
  id                       String            @id @default(uuid())
  scenario                 String            @unique
  name                     String
  description              String            @default("")
  status                   String            @default("active")
  ttsConfig                Json              @default("{}") @map("tts_config")
  agentIdentity            String            @default("") @map("agent_identity")
  communicationStyle       String            @default("") @map("communication_style")
  communicationStylePrompt String            @default("") @map("communication_style_prompt")
  businessGoal             String            @default("") @map("business_goal")
  llmConstraints           Json              @default("[]") @map("llm_constraints")
  systemPrompt             String            @default("") @map("system_prompt")
  greeting                 String            @default("")
  knowledgeBaseId          String            @default("") @map("knowledge_base_id")
  allowedTools             Json              @default("[]") @map("allowed_tools")
  escalationRules          Json              @default("[]") @map("escalation_rules")
  defaultFlowId            String?           @map("default_flow_id")
  defaultFlow              TaskFlow?         @relation("ScenarioDefaultFlow", fields: [defaultFlowId], references: [id], onDelete: SetNull)
  taskFlows                TaskFlow[]        @relation("TaskFlowScenario")
  taskFlowVersions         TaskFlowVersion[] @relation("TaskFlowVersionScenario")
  tasks                    OutboundTask[]
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("outbound_scenarios")
}

model GlobalConfig {
  id              String   @id @default("default")
  globalVariables Json     @default("[]") @map("global_variables")
  apiPlugins      Json     @default("[]") @map("api_plugins")
  outboundRules   Json     @default("{}") @map("outbound_rules")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("global_configs")
}

model Tenant {
  id              String                 @id @default(uuid())
  slug            String                 @unique
  name            String
  status          String                 @default("active")
  metadata        Json                   @default("{}")
  providerConfigs TenantProviderConfig[]
  quotaPolicies   TenantQuotaPolicy[]
  usageEvents     UsageEvent[]
  usageAggregates UsageAggregate[]
  billingAccount  BillingAccount?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("tenants")
}

model TenantProviderConfig {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerType    String   @map("provider_type")
  providerName    String   @map("provider_name")
  enabled         Boolean  @default(true)
  secretRef       String?  @map("secret_ref")
  configEncrypted Json     @default("{}") @map("config_encrypted")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, providerType, providerName])
  @@index([providerType, providerName])
  @@map("tenant_provider_configs")
}

model TenantQuotaPolicy {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric     String
  period     String
  quotaLimit Int      @map("quota_limit")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, metric, period])
  @@index([metric, period])
  @@map("tenant_quota_policies")
}

model UsageEvent {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  idempotencyKey String   @map("idempotency_key")
  metric         String
  period         String   @default("day")
  quantity       Int      @default(1)
  eventAt        DateTime @default(now()) @map("event_at")
  source         String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, metric, period, eventAt])
  @@map("usage_events")
}

model UsageAggregate {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric      String
  period      String
  bucketStart DateTime @map("bucket_start")
  quantity    Int      @default(0)
  eventCount  Int      @default(0) @map("event_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, metric, period, bucketStart])
  @@index([tenantId, period, bucketStart])
  @@map("usage_aggregates")
}

model BillingAccount {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status              String   @default("trial")
  providerCustomerRef String?  @map("provider_customer_ref")
  billingEmail        String?  @map("billing_email")
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("billing_accounts")
}

model VoiceClone {
  id                 String   @id @default(uuid())
  voiceId            String   @unique @map("voice_id")
  name               String
  model              String   @default("cosyvoice")
  promptText         String   @map("prompt_text")
  description        String   @default("")
  status             String   @default("ready")
  sourceFilename     String   @map("source_filename")
  sourceMimeType     String   @map("source_mime_type")
  sourceFilePath     String   @map("source_file_path")
  sourceFileSize     Int      @map("source_file_size")
  previewText        String?  @map("preview_text")
  previewFilePath    String?  @map("preview_file_path")
  previewMimeType    String?  @map("preview_mime_type")
  previewGeneratedAt DateTime? @map("preview_generated_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([status, updatedAt])
  @@map("voice_clones")
}

model TaskFlow {
  id          String            @id @default(uuid())
  name        String
  description String            @default("")
  scenarioId  String?           @map("scenario_id")
  scenarioConfig OutboundScenario? @relation("TaskFlowScenario", fields: [scenarioId], references: [id], onDelete: SetNull)
  defaultForScenarios OutboundScenario[] @relation("ScenarioDefaultFlow")
  status      String            @default("draft")
  nodes       Json              @default("[]")
  edges       Json              @default("[]")
  version     Int               @default(0)
  versions    TaskFlowVersion[]
  tasks       OutboundTask[]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("task_flows")
}

model TaskFlowVersion {
  id          String         @id @default(uuid())
  flowId      String         @map("flow_id")
  flow        TaskFlow       @relation(fields: [flowId], references: [id], onDelete: Restrict)
  version     Int
  name        String
  description String         @default("")
  scenarioId  String?        @map("scenario_id")
  scenarioConfig OutboundScenario? @relation("TaskFlowVersionScenario", fields: [scenarioId], references: [id], onDelete: SetNull)
  scenarioSnapshot Json?     @map("scenario_snapshot")
  nodes       Json
  edges       Json
  tasks       OutboundTask[]
  createdAt   DateTime       @default(now()) @map("created_at")

  @@unique([flowId, version])
  @@index([flowId, createdAt])
  @@map("task_flow_versions")
}

model OutboundTask {
  id            String            @id @default(uuid())
  to            String
  from          String
  scenario      String
  scenarioId    String?           @map("scenario_id")
  scenarioConfig OutboundScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  variables     Json              @default("{}")
  status        String            @default("pending")
  scheduledAt   DateTime          @map("scheduled_at")
  calledAt      DateTime?         @map("called_at")
  endedAt       DateTime?         @map("ended_at")
  duration      Int?
  outcome       String?
  recordingUrl  String?           @map("recording_url")
  intentTags    String[]          @default([]) @map("intent_tags")
  campaignId    String?           @map("campaign_id")
  campaign      Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignLeadId String?          @map("campaign_lead_id")
  campaignLead  CampaignLead?     @relation(fields: [campaignLeadId], references: [id], onDelete: SetNull)
  attemptCount  Int               @default(0) @map("attempt_count")
  flowId        String?           @map("flow_id")
  flow           TaskFlow?        @relation(fields: [flowId], references: [id], onDelete: Restrict)
  flowVersionId String?           @map("flow_version_id")
  flowVersion   TaskFlowVersion?  @relation(fields: [flowVersionId], references: [id], onDelete: Restrict)
  transcripts   TranscriptTurn[]
  events        CallEvent[]
  attempts      CallAttempt[]
  callAnalyses   CallAnalysis[]
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status, scheduledAt])
  @@index([scenarioId])
  @@index([flowVersionId])
  @@index([campaignId, status])
  @@index([campaignLeadId])
  @@map("outbound_tasks")
}

model CallAttempt {
  id             String            @id @default(uuid())
  taskId         String            @map("task_id")
  task           OutboundTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptNo      Int               @map("attempt_no")
  providerCallId String?           @unique @map("provider_call_id")
  status         String            @default("calling")
  startedAt      DateTime          @default(now()) @map("started_at")
  ringingAt      DateTime?         @map("ringing_at")
  answeredAt     DateTime?         @map("answered_at")
  endedAt        DateTime?         @map("ended_at")
  duration       Int?
  hangupCause    String?           @map("hangup_cause")
  recordingUrl   String?           @map("recording_url")
  transcripts    TranscriptTurn[]
  events         CallEvent[]
  analysis       CallAnalysis?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([taskId, attemptNo])
  @@index([taskId, createdAt])
  @@index([status, startedAt])
  @@map("call_attempts")
}

model Campaign {
  id               String           @id @default(uuid())
  name             String
  description      String           @default("")
  scenario         String
  scenarioId       String?          @map("scenario_id")
  flowId           String?          @map("flow_id")
  status           String           @default("draft")
  scheduledAt      DateTime?        @map("scheduled_at")
  concurrencyLimit Int              @default(3) @map("concurrency_limit")
  retryPolicy      Json             @default("{}") @map("retry_policy")
  endCondition     Json             @default("{}") @map("end_condition")
  leads            CampaignLead[]
  importBatches    LeadImportBatch[]
  tasks            OutboundTask[]
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@index([status, scheduledAt])
  @@index([scenario, createdAt])
  @@map("campaigns")
}

model LeadImportBatch {
  id         String         @id @default(uuid())
  campaignId String        @map("campaign_id")
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  filename   String?       @map("filename")
  totalRows  Int           @map("total_rows")
  validRows  Int           @map("valid_rows")
  invalidRows Int          @map("invalid_rows")
  errors     Json          @default("[]")
  leads      CampaignLead[]
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([campaignId, createdAt])
  @@map("lead_import_batches")
}

model CampaignLead {
  id              String          @id @default(uuid())
  campaignId      String          @map("campaign_id")
  campaign        Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  batchId         String?         @map("batch_id")
  batch           LeadImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  rowNumber       Int             @map("row_number")
  phoneNumber     String          @map("phone_number")
  displayName     String?         @map("display_name")
  variables       Json            @default("{}")
  status          String          @default("imported")
  validationError String?         @map("validation_error")
  tasks           OutboundTask[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([campaignId, rowNumber])
  @@index([campaignId, status])
  @@index([batchId])
  @@map("campaign_leads")
}

model CallAnalysis {
  id              String       @id @default(uuid())
  callAttemptId   String       @unique @map("call_attempt_id")
  callAttempt     CallAttempt  @relation(fields: [callAttemptId], references: [id], onDelete: Cascade)
  taskId          String       @map("task_id")
  task            OutboundTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  summary         String
  intent          String
  outcome         String?
  refusalReason   String?      @map("refusal_reason")
  nextAction      String       @map("next_action")
  riskLevel       String       @default("low") @map("risk_level")
  complianceFlags Json         @default("[]") @map("compliance_flags")
  confidence      Float        @default(0)
  correctedAt     DateTime?    @map("corrected_at")
  correctedBy     String?      @map("corrected_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([taskId])
  @@index([riskLevel, createdAt])
  @@map("call_analyses")
}

model ComplianceAuditLog {
  id          String   @id @default(uuid())
  action      String
  subjectType String?  @map("subject_type")
  subjectId   String?  @map("subject_id")
  actorId     String?  @map("actor_id")
  actorName   String?  @map("actor_name")
  details     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([subjectType, subjectId])
  @@map("compliance_audit_logs")
}

model TranscriptTurn {
  id        String       @id @default(uuid())
  taskId    String       @map("task_id")
  task      OutboundTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptId String?      @map("attempt_id")
  attempt   CallAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  role      String
  content   String
  timestamp Float
  emotion   String?
  externalId String?      @map("external_id")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@index([attemptId, createdAt])
  @@unique([taskId, externalId])
  @@map("transcript_turns")
}

model CallEvent {
  id        String       @id @default(uuid())
  taskId    String       @map("task_id")
  task      OutboundTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  attemptId String?      @map("attempt_id")
  attempt   CallAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  type      String
  payload   Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@index([attemptId, createdAt])
  @@map("call_events")
}

model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  type          String
  payload       Json      @default("{}")
  status        String    @default("pending")
  attempts      Int       @default(0)
  availableAt   DateTime  @default(now()) @map("available_at")
  processedAt   DateTime? @map("processed_at")
  lastError     String?   @map("last_error")
  lockedAt      DateTime? @map("locked_at")
  lockedBy      String?   @map("locked_by")
  deduplicationKey String? @unique @map("deduplication_key")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status, availableAt])
  @@index([lockedAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  passwordHash  String        @map("password_hash")
  name          String
  status        String        @default("active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  roles         UserRole[]
  sessions      UserSession[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String           @default("")
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String           @default("")
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}
