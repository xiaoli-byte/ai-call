# Voice Agent WebSocket（Python 后端，含 /asr-stream + /tts-stream）
NEXT_PUBLIC_VOICE_AGENT_WS_URL=ws://localhost:8090

# FunASR（仅用于显示，实际连接由 Python 后端代理）
NEXT_PUBLIC_FUNASR_WS_URL=ws://localhost:10095
NEXT_PUBLIC_FUNASR_MODE=2pass
NEXT_PUBLIC_FUNASR_HOTWORDS=

# TTS（仅用于显示，实际合成由 Python 后端代理）
NEXT_PUBLIC_QWEN_TTS_VOICE=Cherry
NEXT_PUBLIC_TTS_SAMPLE_RATE=16000

# NestJS API 内部地址（服务端私有，不暴露给浏览器；dev 用 rewrites 代理，prod 用 Route Handler 转发）
API_INTERNAL_URL=http://localhost:3001/api

# 知识库微前端（Multi-Zones）：指向 ai-knowledge web 时，/knowledge/* 内嵌 ai-knowledge 原厂知识库 UI；
# 留空则渲染 ai-call 自带的 /knowledge mock 页。dev 填 ai-knowledge web 地址，prod 填网关内网地址。
# 前提：与 ai-knowledge 同域部署（cookie 共享，鉴权免改造）。详见 docs/knowledge-base-microfrontend.md。
# KNOWLEDGE_ZONE_URL=http://localhost:8888
