{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-call.local/contracts/task-api.schema.json",
  "title": "TaskContext",
  "type": "object",
  "required": ["id", "scenario", "variables"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "ownerId": { "type": "string" },
    "scenario": { "type": "string" },
    "scenarioConfig": { "$ref": "#/$defs/scenarioConfig" },
    "variables": { "type": "object", "additionalProperties": { "type": "string" } },
    "flowId": { "type": "string", "format": "uuid" },
    "flowVersionId": { "type": "string", "format": "uuid" },
    "flowVersion": { "$ref": "#/$defs/taskFlowVersion" }
  },
  "$defs": {
    "scenarioConfig": {
      "type": "object",
      "required": ["scenario", "name", "description", "systemPrompt", "greeting", "knowledgeBaseId", "allowedTools", "escalationRules"],
      "properties": {
        "id": { "type": "string" },
        "scenario": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "ttsConfig": { "type": "object" },
        "agentIdentity": { "type": "string" },
        "communicationStyle": { "type": "string" },
        "communicationStylePrompt": { "type": "string" },
        "businessGoal": { "type": "string" },
        "llmConstraints": { "type": "array", "items": { "type": "string" } },
        "systemPrompt": { "type": "string" },
        "greeting": { "type": "string" },
        "knowledgeBaseId": { "type": "string" },
        "allowedTools": { "type": "array", "items": { "type": "string" } },
        "escalationRules": { "type": "array", "items": { "type": "object" } },
        "defaultFlowId": { "type": "string" },
        "dialogRepair": { "type": "object" }
      },
      "additionalProperties": true
    },
    "flowNode": {
      "type": "object",
      "required": ["id", "type", "position", "data"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["start", "dialog", "decision", "action", "end"] },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": { "x": { "type": "number" }, "y": { "type": "number" } },
          "additionalProperties": false
        },
        "data": { "type": "object" }
      },
      "additionalProperties": false
    },
    "flowEdge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "label": { "type": "string" },
        "sourceHandle": { "type": "string" },
        "targetHandle": { "type": "string" }
      },
      "additionalProperties": false
    },
    "taskFlowVersion": {
      "type": "object",
      "required": ["id", "flowId", "version", "name", "description", "nodes", "edges", "createdAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "flowId": { "type": "string", "format": "uuid" },
        "version": { "type": "integer", "minimum": 1 },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "scenarioId": { "type": "string" },
        "scenarioConfig": { "$ref": "#/$defs/scenarioConfig" },
        "nodes": { "type": "array", "items": { "$ref": "#/$defs/flowNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/$defs/flowEdge" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
