# ============================================================
# FunASR Server - 环境变量模板
# 项目内 Python 子服务（替代 Docker 部署）
# 复制为 .env 或继承项目根 .env。未填写的项使用默认值。
# ============================================================

# ----- 服务监听 -----
FUNASR_SERVER_HOST=0.0.0.0
FUNASR_SERVER_PORT=10095

# ----- 设备（默认 GPU；无 GPU 改为 cpu，config.py 会自动降级）-----
FUNASR_SERVER_DEVICE=cuda         # cuda | cpu
FUNASR_SERVER_NGPU=1              # 1 for gpu, 0 for cpu
FUNASR_SERVER_NCPU=4

# ----- 模型（ModelScope ID）-----
FUNASR_SERVER_ASR_MODEL=iic/speech_paraformer-large-contextual_asr_nat-zh-cn-16k-common-vocab8404
FUNASR_SERVER_ASR_MODEL_REVISION=v2.0.4
FUNASR_SERVER_ASR_MODEL_ONLINE=iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-online
FUNASR_SERVER_ASR_MODEL_ONLINE_REVISION=v2.0.4
FUNASR_SERVER_VAD_MODEL=iic/speech_fsmn_vad_zh-cn-16k-common-pytorch
FUNASR_SERVER_VAD_MODEL_REVISION=v2.0.4
FUNASR_SERVER_PUNC_MODEL=iic/punc_ct-transformer_zh-cn-common-vad_realtime-vocab272727
FUNASR_SERVER_PUNC_MODEL_REVISION=v2.0.4

# ----- 句向量模型（/embed 端点，供 voice-agent 意图 embedding 相似度层用，默认关闭见根 .env）-----
# 懒加载：首个 /embed 请求时才加载，不影响启动时间；不配置不影响其余接口。
# 特殊值 mock：跳过真实模型，返回确定性伪向量（本地/CI 无 GPU、无模型时用）。
FUNASR_SERVER_EMBED_MODEL=AI-ModelScope/bge-small-zh-v1.5
# 留空则使用 modelscope 上该模型的默认版本
FUNASR_SERVER_EMBED_MODEL_REVISION=

# ----- SSL（空则禁用 WSS/HTTPS，使用明文 ws/http）-----
FUNASR_SERVER_CERTFILE=
FUNASR_SERVER_KEYFILE=

# ----- 并发限流 -----
FUNASR_SERVER_WORKER_THREADS=4         # ThreadPoolExecutor 大小
FUNASR_SERVER_CONCURRENT_VAD=4         # 同时进行的 VAD 推理数
FUNASR_SERVER_CONCURRENT_ASR_ONLINE=4  # 同时进行的流式 ASR 推理数
FUNASR_SERVER_CONCURRENT_ASR_OFFLINE=2 # 同时进行的整句 ASR 推理数
FUNASR_SERVER_CONCURRENT_PUNC=1        # 同时进行的标点恢复数
FUNASR_SERVER_CONCURRENT_SV=1          # 同时进行的声纹识别数

# ----- HTTP/SSE 接口（与 WS 共享端口 10095）-----
FUNASR_SERVER_TEMP_DIR=temp_dir         # HTTP 上传音频临时目录
FUNASR_SERVER_MAX_UPLOAD_MB=100         # HTTP 上传文件大小上限
FUNASR_SERVER_HOTWORD_PATH=             # 热词 txt 路径（空则不启用）

# ----- 调试 -----
FUNASR_SERVER_SAVE_OFFLINE_SEGMENTS=false  # 保存离线片段为 wav（调试用）
FUNASR_SERVER_SAVE_OFFLINE_SEGMENTS_DIR=offline_segments

# ----- 日志 -----
LOG_LEVEL=INFO
