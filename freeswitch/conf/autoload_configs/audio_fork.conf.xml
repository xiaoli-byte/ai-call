<?xml version="1.0" encoding="utf-8"?>
<!--
  mod_audio_fork 配置

  模块功能：把通话双方的 RTP 音频实时 fork 到 WebSocket 服务器
  下游：Voice Agent（services/voice-agent，Python）的 WebSocket 接收端

  安装说明：
    1. mod_audio_fork 不在 FreeSWITCH 默认镜像中，需单独编译
    2. 源码：https://github.com/iorc/mod_audio_fork
    3. 编译后复制 mod_audio_fork.so 到 /usr/lib/freeswitch/mod/
    4. 也可改用 signalwire 商业版 mod_audio_socket

  数据格式：
    - 第一帧为 JSON metadata（dialog_id, caller_id 等）
    - 后续帧为 16-bit PCM 音频，8kHz/16kHz 可选
    - 双向音频，可区分 caller 与 callee
-->
<configuration name="audio_fork.conf" description="Audio Fork Module">
  <settings>
    <!-- WebSocket 目标地址（Voice Agent 接收音频的端点） -->
    <param name="ws-url" value="ws://host.docker.internal:8090/audio-stream"/>

    <!-- 采样率：电话语音用 8000，VoIP/WebRTC 用 16000 -->
    <param name="sample-rate" value="16000"/>

    <!-- 启用 SSL（生产环境） -->
    <!-- <param name="ssl-cert" value="/path/to/cert.pem"/> -->

    <!-- 重连间隔（秒） -->
    <param name="reconnect-interval" value="5"/>

    <!-- 调试日志 -->
    <param name="debug" value="true"/>
  </settings>
</configuration>
